# ── Required ────────────────────────────────────────────────────────────────
# Postgres connection string.
# On Supabase: Project → Connect → "Transaction pooler" URI (port 6543).
DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Any long random string — signs the login cookies.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional (each one flips a demo engine to LIVE — no code changes) ───────
# Real AI (enrichment, sequences, intent scoring). console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Real email sending with open tracking. resend.com (free: 3,000/month)
# RESEND_API_KEY=re_...
# EMAIL_FROM="Your Name <you@your-verified-domain.com>"

# Real lead database search. apollo.io
# APOLLO_API_KEY=...

# Public URL of the deployed app (used for the open-tracking pixel).
# On Vercel this is detected automatically; set it only for custom domains.
# NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app
